name: Payment Mandate
description: >
  Payment mandate authorizing a grantee to execute payment requests on behalf of a granter,
  under explicit limits, with deterministic spend tracking and optional linked PayNote bootstrap rules.

granterType:
  type: Text
  description: |
    Party granting authority to use funds:
    - merchant
    - customer

granterId:
  type: Text
  description: |
    Identifier of the granting party:
    - merchantId when granterType is merchant
    - customerId (bank user id) when granterType is customer

granteeType:
  type: Text
  description: |
    Party allowed to invoke this mandate:
    - documentId
    - merchantId
    - customerId

granteeId:
  type: Text
  description: Identifier interpreted according to granteeType.

amountLimit:
  type: Integer
  description: Maximum amount in minor currency units allowed by this mandate.

currency:
  type: Common/Currency
  description: Currency code used for amountLimit validation.

amountReserved:
  type: Integer
  description: >
    Running reserved amount in minor currency units.
    Increased after successful reserve/authorize, decreased after release/capture.

amountCaptured:
  type: Integer
  description: >
    Running captured amount in minor currency units.
    Increased after successful capture.

sourceAccount:
  type: Text
  description: >
    Funds source to use when this mandate executes:
    - root (uses root account context; for merchant this maps to active credit line)
    - specific account number

expiresAt:
  type: Common/Timestamp
  description: Optional mandate expiry timestamp.

revokedAt:
  type: Common/Timestamp
  description: Optional revocation timestamp. When set, mandate is inactive.

allowLinkedPayNote:
  type: Boolean
  description: Whether this mandate allows linked PayNote startup after charge execution.

allowedPayNotes:
  type: List
  itemType:
    typeBlueId:
      type: Text
      description: >
        Optional blue-id of an allowed PayNote type.
        Mutually exclusive with documentBlueId.
    documentBlueId:
      type: Text
      description: >
        Optional blue-id of an allowed concrete PayNote document.
        Mutually exclusive with typeBlueId.
  description: >
    Optional linked PayNote allowlist. Used only when allowLinkedPayNote is true.
    Missing list means wildcard (any linked PayNote is allowed).
    Each entry must set exactly one selector: typeBlueId or documentBlueId.

allowedPaymentCounterparties:
  type: List
  itemType:
    counterpartyType:
      type: Text
      description: |
        Allowed payment counterparty identifier type:
        - merchantId
        - customerId
        - accountNumber
    counterpartyId:
      type: Text
      description: Counterparty identifier interpreted according to counterpartyType.
  description: >
    Optional payment counterparty allowlist.
    Missing list means wildcard (any counterparty is allowed).

chargeAttempts:
  type: Dictionary
  keyType: Text
  valueType:
    amountMinor:
      type: Integer
      description: Requested amount in minor currency units.
    currency:
      type: Common/Currency
      description: Requested currency.
    counterpartyType:
      type: Text
      description: Counterparty identifier type ("merchantId" | "customerId" | "accountNumber").
    counterpartyId:
      type: Text
      description: Counterparty identifier interpreted according to counterpartyType.
    chargeMode:
      type: Text
      description: Requested charge mode ("authorize_only" | "authorize_and_capture").
    authorizationStatus:
      type: Text
      description: Authorization decision status ("approved" | "rejected").
    authorizationReason:
      type: Text
      description: Optional authorization rejection reason.
    authorizationRespondedAt:
      type: Common/Timestamp
      description: Timestamp of authorization decision response.
    authorizedAmountMinor:
      type: Integer
      description: Authorized amount reserved against mandate capacity for this attempt.
    settled:
      type: Boolean
      description: Whether mandate accepted settlement for this attempt.
    lastSettlementRequestStatus:
      type: Text
      description: Last settlement request status received from bank ("succeeded" | "failed").
    lastSettlementProcessingStatus:
      type: Text
      description: Mandate processing status for last settlement ("accepted" | "rejected").
    settlementReason:
      type: Text
      description: Optional settlement rejection/info reason.
    settlementRespondedAt:
      type: Common/Timestamp
      description: Timestamp of last settlement processing response.
    reservedDeltaMinor:
      type: Integer
      description: Reserved delta applied for accepted settlement.
    capturedDeltaMinor:
      type: Integer
      description: Captured delta applied for accepted settlement.
    holdId:
      type: Text
      description: Optional hold id associated with settlement.
    transactionId:
      type: Text
      description: Optional transaction id associated with settlement.
    lastSettlementId:
      type: Text
      description: Optional last applied settlement id for idempotency tracking.
  description: Stateful map of authorizationId -> authorization state (authorization + settlement).

contracts:
  granterChannel:
    type: MyOS/MyOS Timeline Channel
    description: Granting party timeline channel.

  granteeChannel:
    type: MyOS/MyOS Timeline Channel
    description: Grantee timeline channel (party allowed to use the mandate).

  guarantorChannel:
    type: MyOS/MyOS Timeline Channel
    description: Bank/admin channel executing mandate checks and settlement updates.

  initLifecycleChannel:
    type: Core/Lifecycle Event Channel
    event:
      type: Core/Document Processing Initiated

  initialize:
    type: Conversation/Sequential Workflow
    channel: initLifecycleChannel
    steps:
      - name: Initialize mandate runtime state
        type: Conversation/Update Document
        changeset:
          - op: replace
            path: /chargeAttempts
            val: {}

  authorizeSpend:
    type: Conversation/Operation
    description: Validate a charge attempt against mandate policy and reserve capacity.
    channel: guarantorChannel
    request:
      type: PayNote/Payment Mandate Spend Authorization Requested

  authorizeSpendImpl:
    type: Conversation/Sequential Workflow Operation
    operation: authorizeSpend
    steps:
      - name: Decide Spend Authorization
        type: Conversation/JavaScript Code
        code: |
          const documentCanonical = document.canonical('/');
          const requestCanonical = eventCanonical
            ? canon.at(eventCanonical, '/message/request')
            : undefined;

          const requestedAtNode = requestCanonical
            ? canon.at(requestCanonical, '/requestedAt')
            : undefined;
          const requestedAtRaw = requestedAtNode ? canon.unwrap(requestedAtNode) : '';
          const requestedAt = typeof requestedAtRaw === 'string' ? requestedAtRaw : '';
          const nowIso =
            requestedAt ||
            (typeof event.timestamp === 'string' ? event.timestamp : '');

          const normalizeTimestamp = function (value) {
            if (typeof value !== 'string' || !value) {
              return '';
            }
            let digits = '';
            let index = 0;
            while (index < value.length) {
              const code = value.charCodeAt(index);
              if (code >= 48 && code <= 57) {
                digits += value.charAt(index);
              }
              index += 1;
            }
            if (digits.length < 14) {
              return '';
            }
            return digits.slice(0, 14);
          };

          const authorizationIdNode = requestCanonical
            ? canon.at(requestCanonical, '/authorizationId')
            : undefined;
          const authorizationIdRaw = authorizationIdNode
            ? canon.unwrap(authorizationIdNode)
            : '';
          const authorizationId =
            typeof authorizationIdRaw === 'string' ? authorizationIdRaw : '';

          const amountMinorNode = requestCanonical
            ? canon.at(requestCanonical, '/amountMinor')
            : undefined;
          const amountMinorRaw = amountMinorNode ? canon.unwrap(amountMinorNode) : 0;
          const amountMinor = typeof amountMinorRaw === 'number' ? amountMinorRaw : 0;

          const counterpartyTypeNode = requestCanonical
            ? canon.at(requestCanonical, '/counterpartyType')
            : undefined;
          const counterpartyTypeRaw = counterpartyTypeNode
            ? canon.unwrap(counterpartyTypeNode)
            : '';
          const counterpartyType =
            typeof counterpartyTypeRaw === 'string' ? counterpartyTypeRaw : '';

          const counterpartyIdNode = requestCanonical
            ? canon.at(requestCanonical, '/counterpartyId')
            : undefined;
          const counterpartyIdRaw = counterpartyIdNode
            ? canon.unwrap(counterpartyIdNode)
            : '';
          const counterpartyId =
            typeof counterpartyIdRaw === 'string' ? counterpartyIdRaw : '';

          const requestedCurrencyNode = requestCanonical
            ? canon.at(requestCanonical, '/currency')
            : undefined;
          const requestedCurrencyRaw = requestedCurrencyNode
            ? canon.unwrap(requestedCurrencyNode)
            : '';
          const requestedCurrency =
            typeof requestedCurrencyRaw === 'string' ? requestedCurrencyRaw : '';

          const chargeAttemptsNode = canon.at(documentCanonical, '/chargeAttempts');
          const chargeAttemptsRaw = chargeAttemptsNode
            ? canon.unwrap(chargeAttemptsNode)
            : {};
          const chargeAttempts =
            chargeAttemptsRaw &&
            typeof chargeAttemptsRaw === 'object' &&
            !Array.isArray(chargeAttemptsRaw)
              ? chargeAttemptsRaw
              : {};
          const nextChargeAttempts = { ...chargeAttempts };

          const existingAttemptRaw = authorizationId
            ? chargeAttempts[authorizationId]
            : undefined;
          const existingAttempt =
            existingAttemptRaw &&
            typeof existingAttemptRaw === 'object' &&
            !Array.isArray(existingAttemptRaw)
              ? existingAttemptRaw
              : null;
          const existingDecision =
            existingAttempt &&
            typeof existingAttempt.authorizationStatus === 'string'
              ? existingAttempt.authorizationStatus
              : '';
          const existingReason =
            existingAttempt && typeof existingAttempt.authorizationReason === 'string'
              ? existingAttempt.authorizationReason
              : '';

          const amountLimitNode = canon.at(documentCanonical, '/amountLimit');
          const amountLimitRaw = amountLimitNode ? canon.unwrap(amountLimitNode) : 0;
          const amountLimit = typeof amountLimitRaw === 'number' ? amountLimitRaw : 0;

          const amountReservedNode = canon.at(documentCanonical, '/amountReserved');
          const amountReservedRaw = amountReservedNode
            ? canon.unwrap(amountReservedNode)
            : 0;
          const amountReserved =
            typeof amountReservedRaw === 'number' ? amountReservedRaw : 0;

          const amountCapturedNode = canon.at(documentCanonical, '/amountCaptured');
          const amountCapturedRaw = amountCapturedNode
            ? canon.unwrap(amountCapturedNode)
            : 0;
          const amountCaptured =
            typeof amountCapturedRaw === 'number' ? amountCapturedRaw : 0;

          const mandateCurrencyNode = canon.at(documentCanonical, '/currency');
          const mandateCurrencyRaw = mandateCurrencyNode
            ? canon.unwrap(mandateCurrencyNode)
            : '';
          const mandateCurrency =
            typeof mandateCurrencyRaw === 'string' ? mandateCurrencyRaw : '';

          const expiresAtNode = canon.at(documentCanonical, '/expiresAt');
          const expiresAtRaw = expiresAtNode ? canon.unwrap(expiresAtNode) : '';
          const expiresAt = typeof expiresAtRaw === 'string' ? expiresAtRaw : '';

          const revokedAtNode = canon.at(documentCanonical, '/revokedAt');
          const revokedAtRaw = revokedAtNode ? canon.unwrap(revokedAtNode) : '';
          const revokedAt = typeof revokedAtRaw === 'string' ? revokedAtRaw : '';

          const nowComparable = normalizeTimestamp(nowIso);

          const allowedCounterpartiesNode = canon.at(
            documentCanonical,
            '/allowedPaymentCounterparties'
          );
          const allowedCounterpartiesRaw = allowedCounterpartiesNode
            ? canon.unwrap(allowedCounterpartiesNode)
            : [];
          const allowedCounterparties = Array.isArray(allowedCounterpartiesRaw)
            ? allowedCounterpartiesRaw
            : [];
          const isCounterpartyAllowed =
            allowedCounterparties.length === 0 ||
            allowedCounterparties.some(function (item) {
              const itemType =
                item && typeof item.counterpartyType === 'string'
                  ? item.counterpartyType
                  : '';
              const itemId =
                item && typeof item.counterpartyId === 'string'
                  ? item.counterpartyId
                  : '';
              return (
                item &&
                itemType === counterpartyType &&
                itemId === counterpartyId
              );
            });

          let status = 'rejected';
          let reason = '';
          let nextAmountReserved = amountReserved;

          if (existingDecision === 'approved' || existingDecision === 'rejected') {
            status = existingDecision;
            reason = existingDecision === 'rejected' ? existingReason : '';
          } else if (!authorizationId) {
            reason = 'Missing authorizationId.';
          } else if (amountMinor <= 0) {
            reason = 'Amount must be greater than zero.';
          } else if (!requestedCurrency || requestedCurrency !== mandateCurrency) {
            reason = 'Currency does not match mandate currency.';
          } else if (revokedAt) {
            reason = 'Mandate is revoked.';
          } else if (
            expiresAt &&
            normalizeTimestamp(expiresAt) &&
            nowComparable &&
            normalizeTimestamp(expiresAt) < nowComparable
          ) {
            reason = 'Mandate is expired.';
          } else if (!isCounterpartyAllowed) {
            reason = 'Counterparty is not allowed by mandate.';
          } else if (amountReserved + amountCaptured + amountMinor > amountLimit) {
            reason = 'Mandate amount limit exceeded.';
          } else {
            status = 'approved';
            nextAmountReserved = amountReserved + amountMinor;
          }

          if (authorizationId && !existingDecision) {
            const chargeModeNode = requestCanonical
              ? canon.at(requestCanonical, '/chargeMode')
              : undefined;
            const chargeModeRaw = chargeModeNode ? canon.unwrap(chargeModeNode) : '';
            const chargeMode = typeof chargeModeRaw === 'string' ? chargeModeRaw : '';

            nextChargeAttempts[authorizationId] = {
              amountMinor,
              currency: requestedCurrency,
              counterpartyType,
              counterpartyId,
              chargeMode,
              authorizationStatus: status,
              authorizationReason: reason,
              authorizationRespondedAt: nowIso,
              authorizedAmountMinor: status === 'approved' ? amountMinor : 0,
              settled: false,
              lastSettlementRequestStatus: '',
              lastSettlementProcessingStatus: '',
              settlementReason: '',
              settlementRespondedAt: '',
              reservedDeltaMinor: 0,
              capturedDeltaMinor: 0,
              holdId: '',
              transactionId: ''
            };
          }

          const remainingAmountMinor = Math.max(
            0,
            amountLimit - (nextAmountReserved + amountCaptured)
          );

          const responseEvent = {
            type: 'PayNote/Payment Mandate Spend Authorization Responded',
            authorizationId,
            status,
            remainingAmountMinor,
            respondedAt: nowIso
          };

          if (reason) {
            responseEvent.reason = reason;
          }

          return {
            nextChargeAttempts: nextChargeAttempts,
            nextAmountReserved: nextAmountReserved,
            events: [responseEvent]
          };

      - name: Persist Authorization Decision
        type: Conversation/Update Document
        changeset:
          - op: replace
            path: /chargeAttempts
            val: "${steps['Decide Spend Authorization'].nextChargeAttempts}"
          - op: replace
            path: /amountReserved
            val: "${steps['Decide Spend Authorization'].nextAmountReserved}"

  settleSpend:
    type: Conversation/Operation
    description: Apply final reserve/capture deltas for a previously authorized charge attempt.
    channel: guarantorChannel
    request:
      type: PayNote/Payment Mandate Spend Settled

  settleSpendImpl:
    type: Conversation/Sequential Workflow Operation
    operation: settleSpend
    steps:
      - name: Validate and Apply Settlement
        type: Conversation/JavaScript Code
        code: |
          const documentCanonical = document.canonical('/');
          const requestCanonical = eventCanonical
            ? canon.at(eventCanonical, '/message/request')
            : undefined;

          const settledAtNode = requestCanonical
            ? canon.at(requestCanonical, '/settledAt')
            : undefined;
          const settledAtRaw = settledAtNode ? canon.unwrap(settledAtNode) : '';
          const settledAt = typeof settledAtRaw === 'string' ? settledAtRaw : '';
          const nowIso =
            settledAt || (typeof event.timestamp === 'string' ? event.timestamp : '');

          const authorizationIdNode = requestCanonical
            ? canon.at(requestCanonical, '/authorizationId')
            : undefined;
          const authorizationIdRaw = authorizationIdNode
            ? canon.unwrap(authorizationIdNode)
            : '';
          const authorizationId =
            typeof authorizationIdRaw === 'string' ? authorizationIdRaw : '';

          const settlementStatusNode = requestCanonical
            ? canon.at(requestCanonical, '/status')
            : undefined;
          const settlementStatusRaw = settlementStatusNode
            ? canon.unwrap(settlementStatusNode)
            : '';
          const settlementStatus =
            typeof settlementStatusRaw === 'string' ? settlementStatusRaw : '';

          const reservedDeltaNode = requestCanonical
            ? canon.at(requestCanonical, '/reservedDeltaMinor')
            : undefined;
          const reservedDeltaRaw = reservedDeltaNode ? canon.unwrap(reservedDeltaNode) : 0;
          const reservedDeltaMinor =
            typeof reservedDeltaRaw === 'number' ? reservedDeltaRaw : 0;

          const capturedDeltaNode = requestCanonical
            ? canon.at(requestCanonical, '/capturedDeltaMinor')
            : undefined;
          const capturedDeltaRaw = capturedDeltaNode ? canon.unwrap(capturedDeltaNode) : 0;
          const capturedDeltaMinor =
            typeof capturedDeltaRaw === 'number' ? capturedDeltaRaw : 0;

          const amountLimitNode = canon.at(documentCanonical, '/amountLimit');
          const amountLimitRaw = amountLimitNode ? canon.unwrap(amountLimitNode) : 0;
          const amountLimit = typeof amountLimitRaw === 'number' ? amountLimitRaw : 0;

          const amountReservedNode = canon.at(documentCanonical, '/amountReserved');
          const amountReservedRaw = amountReservedNode
            ? canon.unwrap(amountReservedNode)
            : 0;
          const amountReserved =
            typeof amountReservedRaw === 'number' ? amountReservedRaw : 0;

          const amountCapturedNode = canon.at(documentCanonical, '/amountCaptured');
          const amountCapturedRaw = amountCapturedNode
            ? canon.unwrap(amountCapturedNode)
            : 0;
          const amountCaptured =
            typeof amountCapturedRaw === 'number' ? amountCapturedRaw : 0;

          const chargeAttemptsNode = canon.at(documentCanonical, '/chargeAttempts');
          const chargeAttemptsRaw = chargeAttemptsNode
            ? canon.unwrap(chargeAttemptsNode)
            : {};
          const chargeAttempts =
            chargeAttemptsRaw &&
            typeof chargeAttemptsRaw === 'object' &&
            !Array.isArray(chargeAttemptsRaw)
              ? chargeAttemptsRaw
              : {};
          const nextChargeAttempts = { ...chargeAttempts };

          const existingAttemptRaw = authorizationId
            ? chargeAttempts[authorizationId]
            : undefined;
          const existingAttempt =
            existingAttemptRaw &&
            typeof existingAttemptRaw === 'object' &&
            !Array.isArray(existingAttemptRaw)
              ? existingAttemptRaw
              : null;

          const alreadySettled = !!existingAttempt && existingAttempt.settled === true;
          const approved =
            !!existingAttempt &&
            typeof existingAttempt.authorizationStatus === 'string' &&
            existingAttempt.authorizationStatus === 'approved';
          const authorizedAmount =
            existingAttempt && typeof existingAttempt.authorizedAmountMinor === 'number'
              ? existingAttempt.authorizedAmountMinor
              : 0;

          const holdIdNode = requestCanonical
            ? canon.at(requestCanonical, '/holdId')
            : undefined;
          const holdIdRaw = holdIdNode ? canon.unwrap(holdIdNode) : '';
          const holdId = typeof holdIdRaw === 'string' ? holdIdRaw : '';

          const transactionIdNode = requestCanonical
            ? canon.at(requestCanonical, '/transactionId')
            : undefined;
          const transactionIdRaw = transactionIdNode
            ? canon.unwrap(transactionIdNode)
            : '';
          const transactionId =
            typeof transactionIdRaw === 'string' ? transactionIdRaw : '';

          const settlementIdNode = requestCanonical
            ? canon.at(requestCanonical, '/settlementId')
            : undefined;
          const settlementIdRaw = settlementIdNode
            ? canon.unwrap(settlementIdNode)
            : '';
          const settlementId =
            typeof settlementIdRaw === 'string' ? settlementIdRaw : '';

          const requestReasonNode = requestCanonical
            ? canon.at(requestCanonical, '/reason')
            : undefined;
          const requestReasonRaw = requestReasonNode
            ? canon.unwrap(requestReasonNode)
            : '';
          const requestReason =
            typeof requestReasonRaw === 'string' ? requestReasonRaw : '';

          let status = 'rejected';
          let reason = '';
          let nextAmountReserved = amountReserved;
          let nextAmountCaptured = amountCaptured;
          let nextAttempt = existingAttempt ? { ...existingAttempt } : null;

          if (!authorizationId) {
            reason = 'Missing authorizationId.';
          } else if (alreadySettled) {
            status = 'accepted';
            reason = 'Authorization already settled.';
          } else if (!approved) {
            reason = 'Authorization is not approved.';
          } else if (
            settlementStatus !== 'succeeded' &&
            settlementStatus !== 'failed'
          ) {
            reason = 'Unsupported settlement status.';
          } else if (capturedDeltaMinor < 0) {
            reason = 'capturedDeltaMinor cannot be negative.';
          } else if (
            settlementStatus === 'failed' &&
            capturedDeltaMinor !== 0
          ) {
            reason = 'capturedDeltaMinor must be 0 for failed settlement.';
          } else if (capturedDeltaMinor > authorizedAmount) {
            reason = 'capturedDeltaMinor exceeds authorized amount.';
          } else {
            const candidateAmountReserved = amountReserved + reservedDeltaMinor;
            const candidateAmountCaptured = amountCaptured + capturedDeltaMinor;
            const candidateUsed = candidateAmountReserved + candidateAmountCaptured;

            if (candidateAmountReserved < 0) {
              reason = 'Settlement would make amountReserved negative.';
            } else if (candidateAmountCaptured < 0) {
              reason = 'Settlement would make amountCaptured negative.';
            } else if (candidateUsed > amountLimit) {
              reason = 'Settlement would exceed amountLimit.';
            } else {
              status = 'accepted';
              nextAmountReserved = candidateAmountReserved;
              nextAmountCaptured = candidateAmountCaptured;
              nextAttempt = { ...existingAttempt };
              nextAttempt.settled = true;
              nextAttempt.lastSettlementRequestStatus = settlementStatus;
              nextAttempt.lastSettlementProcessingStatus = 'accepted';
              nextAttempt.settlementReason = requestReason;
              nextAttempt.settlementRespondedAt = nowIso;
              nextAttempt.reservedDeltaMinor = reservedDeltaMinor;
              nextAttempt.capturedDeltaMinor = capturedDeltaMinor;
              nextAttempt.holdId = holdId;
              nextAttempt.transactionId = transactionId;
              nextAttempt.lastSettlementId = settlementId;
              nextChargeAttempts[authorizationId] = nextAttempt;
            }
          }

          if (nextAttempt && status === 'rejected') {
            nextAttempt = { ...nextAttempt };
            nextAttempt.lastSettlementRequestStatus = settlementStatus;
            nextAttempt.lastSettlementProcessingStatus = 'rejected';
            nextAttempt.settlementReason = reason;
            nextAttempt.settlementRespondedAt = nowIso;
            nextAttempt.lastSettlementId = settlementId;
            nextChargeAttempts[authorizationId] = nextAttempt;
          }

          const responseEvent = {
            type: 'PayNote/Payment Mandate Spend Settlement Responded',
            authorizationId,
            settlementId,
            status,
            amountReserved: nextAmountReserved,
            amountCaptured: nextAmountCaptured,
            respondedAt: nowIso
          };

          if (reason) {
            responseEvent.reason = reason;
          }

          return {
            nextChargeAttempts: nextChargeAttempts,
            nextAmountReserved: nextAmountReserved,
            nextAmountCaptured: nextAmountCaptured,
            events: [responseEvent]
          };

      - name: Persist Settlement
        type: Conversation/Update Document
        changeset:
          - op: replace
            path: /chargeAttempts
            val: "${steps['Validate and Apply Settlement'].nextChargeAttempts}"
          - op: replace
            path: /amountReserved
            val: "${steps['Validate and Apply Settlement'].nextAmountReserved}"
          - op: replace
            path: /amountCaptured
            val: "${steps['Validate and Apply Settlement'].nextAmountCaptured}"
